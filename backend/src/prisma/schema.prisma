generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum UserRole {
  OWNER
  MANAGER
  BARBER
  RECEPTIONIST
  CLIENT
}

enum AppointmentStatus {
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum TransactionType {
  INCOME
  EXPENSE
  WITHDRAWAL
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          UserRole @default(CLIENT)
  phone         String?
  avatar        String?
  active        Boolean  @default(true)
  refreshToken  String?
  lastAccess    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees     Employee[]
  notifications Notification[]
  cashRegisters CashRegister[]
  cashMovements CashMovement[]
  activities    ActivityLog[]
}

model Employee {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  cpf           String?  @unique
  role          String   @default("BARBER")
  commission    Float    @default(0)
  active        Boolean  @default(true)
  workStartTime String?
  workEndTime   String?
  workDays      String?
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments        Appointment[]
  employeeServices    EmployeeService[]
  commissionRecords   CommissionRecord[]
  workSchedule        WorkSchedule[]
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  duration    Int
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments      Appointment[]
  employeeServices  EmployeeService[]
  favoriteServices  FavoriteService[]
}

model EmployeeService {
  employeeId  String
  serviceId   String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([employeeId, serviceId])
}

model Client {
  id              String   @id @default(uuid())
  name            String
  phone           String?
  whatsapp        String?
  email           String?
  photo           String?
  birthDate       DateTime?
  birthDateStr    String?
  notes           String?
  lastVisit       DateTime?
  nextAppointment DateTime?
  totalVisits     Int      @default(0)
  totalSpent      Float    @default(0)
  userId          String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments          Appointment[]
  favoriteServices      FavoriteService[]
}

model FavoriteService {
  clientId  String
  serviceId String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([clientId, serviceId])
}

model Appointment {
  id          String            @id @default(uuid())
  date        DateTime
  status      AppointmentStatus @default(CONFIRMED)
  notes       String?
  totalValue  Float
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  serviceId   String
  service     Service   @relation(fields: [serviceId], references: [id])
  cashierId   String?
  cashier     Cashier?  @relation(fields: [cashierId], references: [id])
  commission  CommissionRecord[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  cost        Float?
  stock       Int      @default(0)
  minStock    Int      @default(0)
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockMovements StockMovement[]
}

model StockMovement {
  id        String   @id @default(uuid())
  type      String
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CashRegister {
  id        String   @id @default(uuid())
  openDate  DateTime @default(now())
  closeDate DateTime?
  initialAmount Float @default(0)
  finalAmount    Float?
  status    String   @default("OPEN")
  notes     String?

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  movements CashMovement[]
}

model CashMovement {
  id          String          @id @default(uuid())
  type        TransactionType
  description String
  amount      Float
  paymentMethod PaymentMethod?
  createdAt   DateTime        @default(now())

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
}

model Cashier {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  totalReceived Float    @default(0)
  totalCash     Float    @default(0)
  totalPix      Float    @default(0)
  totalCard     Float    @default(0)
  totalExpenses Float    @default(0)
  totalWithdrawals Float @default(0)
  finalBalance  Float    @default(0)
  status        String   @default("OPEN")
  openTime      DateTime @default(now())
  closeTime     DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
}

model CommissionRecord {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  serviceValue Float
  commissionPercent Float
  commissionValue Float
  paid        Boolean  @default(false)
  paidDate    DateTime?

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  appointmentId String @unique
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model FinancialRecord {
  id          String          @id @default(uuid())
  type        TransactionType
  description String
  amount      Float
  paymentMethod PaymentMethod?
  dueDate     DateTime?
  paidDate    DateTime?
  status      String          @default("PENDING")
  category    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model WorkSchedule {
  id        String   @id @default(uuid())
  dayOfWeek Int
  startTime String
  endTime   String
  active    Boolean  @default(true)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  entity    String?
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}
